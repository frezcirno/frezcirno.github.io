body {
    background-image: url('http://cdn.7c00h.xyz/background.jpg');
    background-repeat: no-repeat;
    background-attachment: fixed; //不重复
    background-size: cover; //填充
    background-position: 50% 50%;
}

//博客内容透明化
//文章内容的透明度设置
.posts-expand {
  opacity: 0.95;
}

//侧边框的透明度设置
.sidebar {
  opacity: 0.9;
}

//菜单栏的透明度设置
.header-inner {
  background: rgba(255,255,255,0.9);
}

//搜索框（local-search）的透明度设置
.popup {
  opacity: 0.9;
}